{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "ContentStorage": {
    "BasePath": "../../content/storage",
    "CacheDurationSeconds": 3600
  },
  "Streaming": {
    "SegmentDurationSeconds": 4,
    "BufferSizeBytes": 1048576
  }
}
