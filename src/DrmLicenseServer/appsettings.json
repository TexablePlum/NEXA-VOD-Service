{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JWT": {
    "Issuer": "NexaDrmServer",
    "Audience": "NexaClient",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },
  "Security": {
    "RateLimiting": {
      "LoginAttemptsPerIp": 5,
      "WindowMinutes": 15
    },
    "ConcurrentStreams": {
      "Free": 1,
      "Basic": 2,
      "Pro": 4
    }
  }
}