{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=nexa_drm;Username=nexa;Password=nexa123"
  },

  "Redis": {
    "ConnectionString": "localhost:6379"
  },

  "Jwt": {
    "Secret": "NEXA-JWT-SECRET-KEY-CHANGE-IN-PRODUCTION-MIN-32-CHARS",
    "Issuer": "NexaDRMServer",
    "Audience": "NexaClient",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },

  "License": {
    "ExpirationHours": 8,
    "RenewalThresholdMinutes": 30,
    "ConcurrentStreamLimits": {
      "free": 1,
      "basic": 1,
      "pro": 2
    }
  },

  "UserRateLimiting": {
    "Enabled": true,
    "LicenseEndpoints": {
      "Period": "1m",
      "Limit": 10
    }
  },

  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 100
      },
      {
        "Endpoint": "*",
        "Period": "15m",
        "Limit": 1000
      }
    ]
  }
}
