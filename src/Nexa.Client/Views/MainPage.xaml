<Page
    x:Class="Nexa.Client.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <!-- Aurora Animation -->
        <Storyboard x:Name="AuroraAnimation">
            <DoubleAnimation Storyboard.TargetName="Aurora1Data" Storyboard.TargetProperty="TranslateX"
                             From="-100" To="100" Duration="0:0:12" AutoReverse="True" RepeatBehavior="Forever">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Aurora1Data" Storyboard.TargetProperty="TranslateY"
                             From="-60" To="60" Duration="0:0:16" AutoReverse="True" RepeatBehavior="Forever">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="Aurora2Data" Storyboard.TargetProperty="TranslateX"
                             From="80" To="-80" Duration="0:0:14" AutoReverse="True" RepeatBehavior="Forever">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Aurora2Data" Storyboard.TargetProperty="TranslateY"
                             From="50" To="-50" Duration="0:0:18" AutoReverse="True" RepeatBehavior="Forever">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Page.Resources>

    <Grid Background="#050508">

        <!-- Aurora 1 - lewy górny (purpura) -->
        <Grid Opacity="0.5" RenderTransformOrigin="0.5,0.5" Margin="-100">
            <Grid.RenderTransform>
                <CompositeTransform x:Name="Aurora1Data"/>
            </Grid.RenderTransform>
            <Grid.Background>
                <RadialGradientBrush Center="0.15,0.15" RadiusX="0.7" RadiusY="0.7">
                    <GradientStop Color="#7000FF" Offset="0"/>
                    <GradientStop Color="#507000FF" Offset="0.3"/>
                    <GradientStop Color="#207000FF" Offset="0.6"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Grid.Background>
        </Grid>

        <!-- Aurora 2 - prawy dolny (cyan) -->
        <Grid Opacity="0.45" RenderTransformOrigin="0.5,0.5" Margin="-100">
            <Grid.RenderTransform>
                <CompositeTransform x:Name="Aurora2Data"/>
            </Grid.RenderTransform>
            <Grid.Background>
                <RadialGradientBrush Center="0.85,0.85" RadiusX="0.6" RadiusY="0.6">
                    <GradientStop Color="#00BFFF" Offset="0"/>
                    <GradientStop Color="#5000BFFF" Offset="0.3"/>
                    <GradientStop Color="#2000BFFF" Offset="0.6"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Grid.Background>
        </Grid>

        <!-- Content -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="1"
                        Spacing="24"
                        HorizontalAlignment="Center"
                        MaxWidth="600"
                        Margin="24">

                <!-- Logo NEXA -->
                <StackPanel Orientation="Horizontal"
                            Spacing="12"
                            HorizontalAlignment="Center">
                    <FontIcon Glyph="&#xE714;"
                              FontFamily="Segoe MDL2 Assets"
                              FontSize="42"
                              Margin="0,7,0,0">
                        <FontIcon.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="White" Offset="0.3"/>
                                <GradientStop Color="#CCCCFF" Offset="1.0"/>
                            </LinearGradientBrush>
                        </FontIcon.Foreground>
                    </FontIcon>

                    <TextBlock Text="NEXA"
                               FontSize="48"
                               FontWeight="Bold"
                               Foreground="White"
                               CharacterSpacing="200"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Welcome Message -->
                <StackPanel Spacing="12">
                    <TextBlock x:Name="WelcomeText"
                               Text="Witaj w NEXA!"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="White"
                               HorizontalAlignment="Center"/>

                    <TextBlock x:Name="UserEmailText"
                               Text="Email użytkownika"
                               FontSize="16"
                               Foreground="#AAFFFFFF"
                               HorizontalAlignment="Center"
                               CharacterSpacing="50"/>

                    <TextBlock x:Name="UserPlanText"
                               Text="Plan: Free"
                               FontSize="14"
                               Foreground="#88FFFFFF"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Info Card -->
                <Border Background="#10FFFFFF"
                        CornerRadius="8"
                        Padding="24"
                        Margin="0,16,0,0">
                    <StackPanel Spacing="12">
                        <TextBlock Text="🎉 Pomyślnie zalogowano!"
                                   FontSize="16"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="To jest placeholder strony głównej. Funkcje VOD będą dostępne wkrótce."
                                   FontSize="14"
                                   Foreground="#AAFFFFFF"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   MaxWidth="400"/>
                    </StackPanel>
                </Border>

                <!-- Przycisk Wyloguj -->
                <Button x:Name="LogoutButton"
                        Content="Wyloguj się"
                        HorizontalAlignment="Center"
                        Margin="0,16,0,0"
                        Padding="32,12"
                        Click="LogoutButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
