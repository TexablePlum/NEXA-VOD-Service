<Page
    x:Class="Nexa.Client.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:Nexa.Client.Converters"
    xmlns:models="using:Nexa.Shared.Models"
    mc:Ignorable="d">

    <Page.Resources>
        <!-- Converters -->
        <converters:DurationToStringConverter x:Key="DurationConverter"/>
        <converters:PlanToColorConverter x:Key="PlanColorConverter"/>
        <converters:BoolNegationConverter x:Key="BoolNegationConverter"/>

        <!-- Aurora Animation -->
        <Storyboard x:Name="AuroraAnimation">
            <DoubleAnimation Storyboard.TargetName="Aurora1Data" Storyboard.TargetProperty="TranslateX"
                             From="-100" To="100" Duration="0:0:12" AutoReverse="True" RepeatBehavior="Forever">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Aurora1Data" Storyboard.TargetProperty="TranslateY"
                             From="-60" To="60" Duration="0:0:16" AutoReverse="True" RepeatBehavior="Forever">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="Aurora2Data" Storyboard.TargetProperty="TranslateX"
                             From="80" To="-80" Duration="0:0:14" AutoReverse="True" RepeatBehavior="Forever">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Aurora2Data" Storyboard.TargetProperty="TranslateY"
                             From="50" To="-50" Duration="0:0:18" AutoReverse="True" RepeatBehavior="Forever">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Page.Resources>

    <Grid Background="#050508">

        <!-- Aurora Background -->
        <!-- Aurora 1 - lewy górny (purpura) -->
        <Grid Opacity="0.35" RenderTransformOrigin="0.5,0.5" Margin="-100">
            <Grid.RenderTransform>
                <CompositeTransform x:Name="Aurora1Data"/>
            </Grid.RenderTransform>
            <Grid.Background>
                <RadialGradientBrush Center="0.15,0.15" RadiusX="0.7" RadiusY="0.7">
                    <GradientStop Color="#7000FF" Offset="0"/>
                    <GradientStop Color="#507000FF" Offset="0.3"/>
                    <GradientStop Color="#207000FF" Offset="0.6"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Grid.Background>
        </Grid>

        <!-- Aurora 2 - prawy dolny (cyan) -->
        <Grid Opacity="0.3" RenderTransformOrigin="0.5,0.5" Margin="-100">
            <Grid.RenderTransform>
                <CompositeTransform x:Name="Aurora2Data"/>
            </Grid.RenderTransform>
            <Grid.Background>
                <RadialGradientBrush Center="0.85,0.85" RadiusX="0.6" RadiusY="0.6">
                    <GradientStop Color="#00BFFF" Offset="0"/>
                    <GradientStop Color="#5000BFFF" Offset="0.3"/>
                    <GradientStop Color="#2000BFFF" Offset="0.6"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Grid.Background>
        </Grid>

        <!-- Main Content -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="#10FFFFFF"
                    BorderBrush="#20FFFFFF"
                    BorderThickness="0,0,0,1"
                    Padding="24,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE714;" FontFamily="Segoe MDL2 Assets" FontSize="24" Foreground="White"/>
                        <TextBlock Text="NEXA" FontSize="20" FontWeight="Bold" Foreground="White" CharacterSpacing="100"/>
                    </StackPanel>

                    <!-- Search Box -->
                    <AutoSuggestBox Grid.Column="1"
                                    PlaceholderText="Szukaj filmów..."
                                    Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay}"
                                    QueryIcon="Find"
                                    MaxWidth="400"
                                    Margin="32,0"
                                    HorizontalAlignment="Center"
                                    QuerySubmitted="SearchBox_QuerySubmitted"/>

                    <!-- User Info + Logout -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                        <StackPanel Spacing="2">
                            <TextBlock Text="{x:Bind ViewModel.UserEmail, Mode=OneWay}"
                                       FontSize="12"
                                       Foreground="#AAFFFFFF"
                                       HorizontalAlignment="Right"/>
                            <TextBlock Text="{x:Bind ViewModel.UserPlan, Mode=OneWay}"
                                       FontSize="10"
                                       Foreground="#88FFFFFF"
                                       HorizontalAlignment="Right"/>
                        </StackPanel>

                        <Button Content="Wyloguj"
                                Click="LogoutButton_Click"
                                Background="#20FFFFFF"
                                Foreground="White"
                                Padding="16,8"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content Area -->
            <Grid Grid.Row="1">
                <!-- Loading State -->
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Spacing="16"
                            Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}">
                    <ProgressRing IsActive="True" Width="48" Height="48" Foreground="White"/>
                    <TextBlock Text="Ładowanie katalogu filmów..."
                               FontSize="14"
                               Foreground="#AAFFFFFF"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Error State -->
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Spacing="16"
                            MaxWidth="400"
                            Visibility="{x:Bind ViewModel.HasError, Mode=OneWay}">
                    <FontIcon Glyph="&#xE783;" FontSize="48" Foreground="#FF6B6B"/>
                    <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                               FontSize="14"
                               Foreground="White"
                               TextWrapping="Wrap"
                               TextAlignment="Center"/>
                    <Button Content="Spróbuj ponownie"
                            Command="{x:Bind ViewModel.RefreshCommand}"
                            HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Movies Grid -->
                <ScrollViewer x:Name="MainScrollViewer"
                              ViewChanged="ScrollViewer_ViewChanged"
                              Visibility="{x:Bind ViewModel.HasError, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}">
                    <StackPanel Padding="24" Spacing="24">
                        <!-- Stats Bar -->
                        <Grid>
                            <TextBlock Foreground="#AAFFFFFF" FontSize="14">
                                <Run Text="Znaleziono"/>
                                <Run Text="{x:Bind ViewModel.TotalMovies, Mode=OneWay}" FontWeight="SemiBold"/>
                                <Run Text="filmów"/>
                            </TextBlock>

                            <Button Content="&#xE72C;"
                                    FontFamily="Segoe MDL2 Assets"
                                    Command="{x:Bind ViewModel.RefreshCommand}"
                                    Background="Transparent"
                                    Foreground="White"
                                    HorizontalAlignment="Right"
                                    ToolTipService.ToolTip="Odśwież katalog"/>
                        </Grid>

                        <!-- GridView with Movies -->
                        <GridView x:Name="MovieGrid"
                                  ItemsSource="{x:Bind ViewModel.Movies, Mode=OneWay}"
                                  IsItemClickEnabled="True"
                                  ItemClick="MovieGrid_ItemClick"
                                  SelectionMode="None">
                            <GridView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="4"/>
                                </ItemsPanelTemplate>
                            </GridView.ItemsPanel>

                            <GridView.ItemTemplate>
                                <DataTemplate x:DataType="models:ContentMetadata">
                                    <Border Background="#15FFFFFF"
                                            CornerRadius="8"
                                            Width="280"
                                            Height="420"
                                            Margin="8"
                                            BorderBrush="#30FFFFFF"
                                            BorderThickness="1">
                                        <Border.Shadow>
                                            <ThemeShadow/>
                                        </Border.Shadow>

                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="200"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <!-- Thumbnail -->
                                            <Border Grid.Row="0"
                                                    CornerRadius="8,8,0,0"
                                                    Background="#20FFFFFF">
                                                <Grid>
                                                    <!-- Placeholder gdy nie ma miniaturki -->
                                                    <FontIcon Glyph="&#xE714;"
                                                              FontFamily="Segoe MDL2 Assets"
                                                              FontSize="64"
                                                              Foreground="#40FFFFFF"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>

                                                    <!-- TODO: Właściwa miniaturka z JWT -->
                                                    <!-- <Image Source="{x:Bind ThumbnailUrl}" Stretch="UniformToFill"/> -->

                                                    <!-- Plan Badge -->
                                                    <Border Background="{x:Bind RequiredPlan, Converter={StaticResource PlanColorConverter}}"
                                                            CornerRadius="4"
                                                            Padding="8,4"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Top"
                                                            Margin="8">
                                                        <TextBlock Text="{x:Bind RequiredPlan}"
                                                                   FontSize="10"
                                                                   FontWeight="Bold"
                                                                   Foreground="White"
                                                                   CharacterSpacing="100"/>
                                                    </Border>
                                                </Grid>
                                            </Border>

                                            <!-- Info -->
                                            <StackPanel Grid.Row="1" Padding="16" Spacing="8">
                                                <TextBlock Text="{x:Bind Title}"
                                                           FontSize="16"
                                                           FontWeight="SemiBold"
                                                           Foreground="White"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxLines="2"/>

                                                <TextBlock Text="{x:Bind Description}"
                                                           FontSize="12"
                                                           Foreground="#AAFFFFFF"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxLines="3"
                                                           LineHeight="18"/>

                                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                                                    <FontIcon Glyph="&#xE121;" FontSize="12" Foreground="#88FFFFFF"/>
                                                    <TextBlock Text="{x:Bind DurationSeconds, Converter={StaticResource DurationConverter}}"
                                                               FontSize="12"
                                                               Foreground="#88FFFFFF"/>
                                                </StackPanel>

                                                <!-- Genres -->
                                                <ItemsControl ItemsSource="{x:Bind Genres}" Margin="0,4,0,0">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal" Spacing="4"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="x:String">
                                                            <Border Background="#20FFFFFF"
                                                                    CornerRadius="4"
                                                                    Padding="6,2">
                                                                <TextBlock Text="{x:Bind}"
                                                                           FontSize="10"
                                                                           Foreground="#AAFFFFFF"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </GridView.ItemTemplate>
                        </GridView>

                        <!-- Load More Indicator -->
                        <StackPanel HorizontalAlignment="Center"
                                    Spacing="8"
                                    Visibility="{x:Bind ViewModel.CanLoadMore, Mode=OneWay}">
                            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                          Width="32"
                                          Height="32"
                                          Foreground="White"/>
                            <TextBlock Text="Przewiń, aby załadować więcej..."
                                       FontSize="12"
                                       Foreground="#88FFFFFF"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Page>
