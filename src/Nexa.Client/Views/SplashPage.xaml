<Page
    x:Class="Nexa.Client.Views.SplashPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:Nexa.Client.ViewModels"
    xmlns:converters="using:Nexa.Client.Converters"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <Storyboard x:Name="AuroraAnimation">
            <DoubleAnimation Storyboard.TargetName="Aurora1Data" Storyboard.TargetProperty="TranslateX"
                             From="-100" To="100" Duration="0:0:12" AutoReverse="True" RepeatBehavior="Forever">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Aurora1Data" Storyboard.TargetProperty="TranslateY"
                             From="-60" To="60" Duration="0:0:16" AutoReverse="True" RepeatBehavior="Forever">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="Aurora2Data" Storyboard.TargetProperty="TranslateX"
                             From="80" To="-80" Duration="0:0:14" AutoReverse="True" RepeatBehavior="Forever">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Aurora2Data" Storyboard.TargetProperty="TranslateY"
                             From="50" To="-50" Duration="0:0:18" AutoReverse="True" RepeatBehavior="Forever">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Name="LogoEntrance">
            <DoubleAnimation Storyboard.TargetName="LogoTransform" Storyboard.TargetProperty="Y"
                             From="40" To="0" Duration="0:0:0.8">
                <DoubleAnimation.EasingFunction>
                    <CircleEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="MainContentGrid" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:1.0">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Page.Resources>

    <Grid Background="#050508">

        <!-- Aurora 1 - lewy górny -->
        <Grid Opacity="0.5" RenderTransformOrigin="0.5,0.5" Margin="-100">
            <Grid.RenderTransform>
                <CompositeTransform x:Name="Aurora1Data"/>
            </Grid.RenderTransform>
            <Grid.Background>
                <RadialGradientBrush Center="0.15,0.15" RadiusX="0.7" RadiusY="0.7">
                    <GradientStop Color="#7000FF" Offset="0"/>
                    <GradientStop Color="#507000FF" Offset="0.3"/>
                    <GradientStop Color="#207000FF" Offset="0.6"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Grid.Background>
        </Grid>

        <!-- Aurora 2 - prawy dolny -->
        <Grid Opacity="0.45" RenderTransformOrigin="0.5,0.5" Margin="-100">
            <Grid.RenderTransform>
                <CompositeTransform x:Name="Aurora2Data"/>
            </Grid.RenderTransform>
            <Grid.Background>
                <RadialGradientBrush Center="0.85,0.85" RadiusX="0.6" RadiusY="0.6">
                    <GradientStop Color="#00BFFF" Offset="0"/>
                    <GradientStop Color="#5000BFFF" Offset="0.3"/>
                    <GradientStop Color="#2000BFFF" Offset="0.6"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Grid.Background>
        </Grid>

        <!-- Content -->
        <Grid x:Name="MainContentGrid" Opacity="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="1" 
                        Orientation="Horizontal" 
                        Spacing="15" 
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="0,0,0,40"
                        RenderTransformOrigin="0.5,0.5">
                <StackPanel.RenderTransform>
                    <TranslateTransform x:Name="LogoTransform" Y="40"/>
                </StackPanel.RenderTransform>

                <FontIcon Glyph="&#xE714;" FontFamily="Segoe MDL2 Assets" FontSize="56" Margin="0,7,0,0">
                    <FontIcon.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="White" Offset="0.3"/>
                            <GradientStop Color="#CCCCFF" Offset="1.0"/>
                        </LinearGradientBrush>
                    </FontIcon.Foreground>
                </FontIcon>

                <TextBlock Text="NEXA" 
                           FontSize="64" 
                           FontWeight="Bold" 
                           Foreground="White" 
                           CharacterSpacing="200"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Spacing="15" VerticalAlignment="Top">
                <TextBlock Text="{x:Bind ViewModel.LoadingText, Mode=OneWay}"
                           HorizontalAlignment="Center"
                           Foreground="#AAFFFFFF"
                           FontSize="14"
                           FontWeight="Normal"
                           CharacterSpacing="100"/>

                <ProgressBar IsIndeterminate="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                             Width="150"
                             Height="2"
                             Foreground="{ThemeResource SystemAccentColorLight2}"
                             Background="#33FFFFFF"/>

                <Button Content="Spróbuj ponownie"
                        HorizontalAlignment="Center"
                        Margin="0,10,0,0"
                        Command="{x:Bind ViewModel.RetryCommand}"
                        Visibility="{x:Bind ViewModel.IsRetryVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                        Style="{ThemeResource AccentButtonStyle}"/>
            </StackPanel>

            <TextBlock Grid.Row="4" 
                       Text="v1.0.0 Alpha"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,30"
                       Foreground="#44FFFFFF" 
                       FontSize="12"/>
        </Grid>
    </Grid>
</Page>