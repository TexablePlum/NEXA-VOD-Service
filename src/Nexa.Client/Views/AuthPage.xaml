<Page
    x:Class="Nexa.Client.Views.AuthPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:Nexa.Client.ViewModels"
    xmlns:converters="using:Nexa.Client.Converters"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <converters:PlanToBoolConverter x:Key="PlanToBoolConverter"/>

        <!-- Style dla kart planów -->
        <Style x:Key="PlanCardRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="#10FFFFFF"/>
            <Setter Property="BorderBrush" Value="#33FFFFFF"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>

                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CheckStates">
                                    <VisualState x:Name="Checked">
                                        <VisualState.Setters>
                                            <Setter Target="RootBorder.BorderBrush" Value="{ThemeResource SystemAccentColorLight2}"/>
                                            <Setter Target="RootBorder.BorderThickness" Value="2"/>
                                            <Setter Target="RootBorder.Background" Value="#20FFFFFF"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Unchecked"/>
                                </VisualStateGroup>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="RootBorder.Background" Value="#18FFFFFF"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="RootBorder.Background" Value="#15FFFFFF"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Aurora Animation - identyczna jak w SplashPage -->
        <Storyboard x:Name="AuroraAnimation">
            <DoubleAnimation Storyboard.TargetName="Aurora1Data" Storyboard.TargetProperty="TranslateX"
                             From="-100" To="100" Duration="0:0:12" AutoReverse="True" RepeatBehavior="Forever">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Aurora1Data" Storyboard.TargetProperty="TranslateY"
                             From="-60" To="60" Duration="0:0:16" AutoReverse="True" RepeatBehavior="Forever">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="Aurora2Data" Storyboard.TargetProperty="TranslateX"
                             From="80" To="-80" Duration="0:0:14" AutoReverse="True" RepeatBehavior="Forever">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Aurora2Data" Storyboard.TargetProperty="TranslateY"
                             From="50" To="-50" Duration="0:0:18" AutoReverse="True" RepeatBehavior="Forever">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Content Entrance Animation -->
        <Storyboard x:Name="ContentEntrance">
            <DoubleAnimation Storyboard.TargetName="ContentTransform" Storyboard.TargetProperty="Y"
                             From="30" To="0" Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction>
                    <CircleEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="MainContentGrid" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.8">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Page.Resources>

    <Grid Background="#050508">

        <!-- Aurora 1 - lewy górny (purpura) -->
        <Grid Opacity="0.5" RenderTransformOrigin="0.5,0.5" Margin="-100">
            <Grid.RenderTransform>
                <CompositeTransform x:Name="Aurora1Data"/>
            </Grid.RenderTransform>
            <Grid.Background>
                <RadialGradientBrush Center="0.15,0.15" RadiusX="0.7" RadiusY="0.7">
                    <GradientStop Color="#7000FF" Offset="0"/>
                    <GradientStop Color="#507000FF" Offset="0.3"/>
                    <GradientStop Color="#207000FF" Offset="0.6"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Grid.Background>
        </Grid>

        <!-- Aurora 2 - prawy dolny (cyan) -->
        <Grid Opacity="0.45" RenderTransformOrigin="0.5,0.5" Margin="-100">
            <Grid.RenderTransform>
                <CompositeTransform x:Name="Aurora2Data"/>
            </Grid.RenderTransform>
            <Grid.Background>
                <RadialGradientBrush Center="0.85,0.85" RadiusX="0.6" RadiusY="0.6">
                    <GradientStop Color="#00BFFF" Offset="0"/>
                    <GradientStop Color="#5000BFFF" Offset="0.3"/>
                    <GradientStop Color="#2000BFFF" Offset="0.6"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Grid.Background>
        </Grid>

        <!-- Main Content -->
        <Grid x:Name="MainContentGrid" Opacity="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="1" MaxWidth="420" Margin="24">
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="ContentTransform" Y="30"/>
                </Grid.RenderTransform>

                <StackPanel Spacing="32">
                    <!-- Logo i tytuł -->
                    <StackPanel Spacing="16">
                        <!-- Logo NEXA -->
                        <StackPanel Orientation="Horizontal"
                                    Spacing="12"
                                    HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE714;"
                                      FontFamily="Segoe MDL2 Assets"
                                      FontSize="42">
                                <FontIcon.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="White" Offset="0.3"/>
                                        <GradientStop Color="#CCCCFF" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </FontIcon.Foreground>
                            </FontIcon>

                            <TextBlock Text="NEXA"
                                       FontSize="48"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       CharacterSpacing="200"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Tytuł trybu (Login/Register) -->
                        <TextBlock Text="{x:Bind ViewModel.ModeTitle, Mode=OneWay}"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>
                    </StackPanel>

                    <!-- Formularz -->
                    <StackPanel Spacing="16">
                        <!-- Email -->
                        <StackPanel Spacing="6">
                            <TextBox x:Name="EmailTextBox"
                                     PlaceholderText="Adres email"
                                     Text="{x:Bind ViewModel.Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{x:Bind ViewModel.IsFormEnabled, Mode=OneWay}"
                                     InputScope="EmailSmtpAddress"
                                     FontSize="15"/>

                            <TextBlock Text="{x:Bind ViewModel.EmailError, Mode=OneWay}"
                                       Foreground="#FF6B6B"
                                       FontSize="13"
                                       Margin="12,0,0,0"
                                       Visibility="{x:Bind ViewModel.EmailError, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}}"/>
                        </StackPanel>

                        <!-- Hasło -->
                        <StackPanel Spacing="6">
                            <PasswordBox x:Name="PasswordBox"
                                         PlaceholderText="Hasło"
                                         Password="{x:Bind ViewModel.Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{x:Bind ViewModel.IsFormEnabled, Mode=OneWay}"
                                         FontSize="15"/>

                            <TextBlock Text="{x:Bind ViewModel.PasswordError, Mode=OneWay}"
                                       Foreground="#FF6B6B"
                                       FontSize="13"
                                       Margin="12,0,0,0"
                                       Visibility="{x:Bind ViewModel.PasswordError, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}}"/>
                        </StackPanel>

                        <!-- Potwierdź hasło (tylko w trybie Register) -->
                        <StackPanel Spacing="6"
                                    Visibility="{x:Bind ViewModel.IsRegisterMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <PasswordBox x:Name="ConfirmPasswordBox"
                                         PlaceholderText="Potwierdź hasło"
                                         Password="{x:Bind ViewModel.ConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{x:Bind ViewModel.IsFormEnabled, Mode=OneWay}"
                                         FontSize="15"/>

                            <TextBlock Text="{x:Bind ViewModel.ConfirmPasswordError, Mode=OneWay}"
                                       Foreground="#FF6B6B"
                                       FontSize="13"
                                       Margin="12,0,0,0"
                                       Visibility="{x:Bind ViewModel.ConfirmPasswordError, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}}"/>
                        </StackPanel>

                        <!-- Wybór planu (tylko w trybie Register) -->
                        <StackPanel Spacing="12"
                                    Margin="0,16,0,0"
                                    Visibility="{x:Bind ViewModel.IsRegisterMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="Wybierz plan:"
                                       Foreground="#AAFFFFFF"
                                       FontSize="15"
                                       FontWeight="SemiBold"/>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Free Plan -->
                                <RadioButton Grid.Column="0"
                                             GroupName="PlanSelection"
                                             IsChecked="{x:Bind ViewModel.SelectedPlan, Mode=TwoWay, Converter={StaticResource PlanToBoolConverter}, ConverterParameter=free}"
                                             Style="{StaticResource PlanCardRadioButtonStyle}">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="&#xE946;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="24"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{ThemeResource SystemAccentColorLight2}"/>
                                        <TextBlock Text="Free"
                                                   FontSize="16"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   Foreground="White"/>
                                        <TextBlock Text="720p HD"
                                                   FontSize="13"
                                                   HorizontalAlignment="Center"
                                                   Foreground="#AAFFFFFF"/>
                                    </StackPanel>
                                </RadioButton>

                                <!-- Basic Plan -->
                                <RadioButton Grid.Column="1"
                                             GroupName="PlanSelection"
                                             IsChecked="{x:Bind ViewModel.SelectedPlan, Mode=TwoWay, Converter={StaticResource PlanToBoolConverter}, ConverterParameter=basic}"
                                             Style="{StaticResource PlanCardRadioButtonStyle}">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="&#xE8B7;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="24"
                                                   HorizontalAlignment="Center"
                                                   Foreground="#7000FF"/>
                                        <TextBlock Text="Basic"
                                                   FontSize="16"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   Foreground="White"/>
                                        <TextBlock Text="1080p Full HD"
                                                   FontSize="13"
                                                   HorizontalAlignment="Center"
                                                   Foreground="#AAFFFFFF"/>
                                    </StackPanel>
                                </RadioButton>

                                <!-- Pro Plan -->
                                <RadioButton Grid.Column="2"
                                             GroupName="PlanSelection"
                                             IsChecked="{x:Bind ViewModel.SelectedPlan, Mode=TwoWay, Converter={StaticResource PlanToBoolConverter}, ConverterParameter=pro}"
                                             Style="{StaticResource PlanCardRadioButtonStyle}">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="&#xE734;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="24"
                                                   HorizontalAlignment="Center"
                                                   Foreground="#00BFFF"/>
                                        <TextBlock Text="Pro"
                                                   FontSize="16"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   Foreground="White"/>
                                        <TextBlock Text="8K Ultra HD"
                                                   FontSize="13"
                                                   HorizontalAlignment="Center"
                                                   Foreground="#AAFFFFFF"/>
                                    </StackPanel>
                                </RadioButton>
                            </Grid>
                        </StackPanel>

                        <!-- Remember Me (tylko w trybie Login) -->
                        <CheckBox IsChecked="{x:Bind ViewModel.RememberMe, Mode=TwoWay}"
                                  Content="Zapamiętaj mnie"
                                  Foreground="#AAFFFFFF"
                                  FontSize="14"
                                  Margin="0,8,0,0"
                                  Visibility="{x:Bind ViewModel.IsLoginMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

                        <!-- Forgot Password (tylko w trybie Login) -->
                        <HyperlinkButton Content="Zapomniałeś hasła?"
                                         HorizontalAlignment="Right"
                                         Foreground="#AAFFFFFF"
                                         FontSize="13"
                                         Margin="0,-8,0,0"
                                         Command="{x:Bind ViewModel.ForgotPasswordCommand}"
                                         Visibility="{x:Bind ViewModel.IsLoginMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

                        <!-- Przycisk główny (Login/Register) -->
                        <Button x:Name="PrimaryButton"
                                Content="{x:Bind ViewModel.PrimaryButtonText, Mode=OneWay}"
                                HorizontalAlignment="Stretch"
                                Height="44"
                                FontSize="15"
                                FontWeight="SemiBold"
                                IsEnabled="{x:Bind ViewModel.IsFormEnabled, Mode=OneWay}"
                                Style="{ThemeResource AccentButtonStyle}"
                                Click="PrimaryButton_Click"/>

                        <!-- Loading indicator -->
                        <StackPanel Orientation="Horizontal"
                                    Spacing="12"
                                    HorizontalAlignment="Center"
                                    Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                          Width="20"
                                          Height="20"/>
                            <TextBlock Text="Proszę czekać..."
                                       Foreground="#AAFFFFFF"
                                       FontSize="14"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Toggle Mode (przełącznik Login/Register) -->
                    <StackPanel Orientation="Horizontal"
                                Spacing="6"
                                HorizontalAlignment="Center"
                                Margin="0,8,0,0">
                        <TextBlock Text="{x:Bind ViewModel.SecondaryPromptText, Mode=OneWay}"
                                   Foreground="#99FFFFFF"
                                   FontSize="14"
                                   VerticalAlignment="Center"/>

                        <HyperlinkButton Content="{x:Bind ViewModel.SecondaryActionText, Mode=OneWay}"
                                         Foreground="{ThemeResource SystemAccentColorLight2}"
                                         FontSize="14"
                                         Padding="4,0"
                                         Command="{x:Bind ViewModel.ToggleModeCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Wersja (dół strony) -->
            <TextBlock Grid.Row="2"
                       Text="v1.0.0 Alpha"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Bottom"
                       Margin="0,0,0,30"
                       Foreground="#44FFFFFF"
                       FontSize="12"/>
        </Grid>
    </Grid>
</Page>
