<UserControl
    x:Class="Nexa.Client.Views.Controls.NotificationOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Nexa.Client.Services.Notifications"
    mc:Ignorable="d">

    <Grid>
        <ItemsControl ItemsSource="{x:Bind ViewModel.Notifications, Mode=OneWay}"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Top"
                      Margin="0,50,20,0"
                      MaxWidth="400">

            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Spacing="10"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemContainerTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition FromVerticalOffset="-20" FromHorizontalOffset="0" />
                </TransitionCollection>
            </ItemsControl.ItemContainerTransitions>

            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="models:AppNotification">
                    <InfoBar 
                        Title="{x:Bind Title}"
                        Message="{x:Bind Message}"
                        Severity="{x:Bind Severity}"
                        IsOpen="{x:Bind IsOpen, Mode=TwoWay}"
                        IsClosable="True"
                        Width="320">
                    </InfoBar>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>