<Window
    x:Class="Nexa.Client.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Nexa.Client.Views.Controls"
    Title="NEXA">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt"/>
    </Window.SystemBackdrop>

    <Grid>
        <Frame x:Name="AppFrame"/>

        <Grid x:Name="AppTitleBar" Height="32" VerticalAlignment="Top" Background="Transparent" IsHitTestVisible="True">
            <TextBlock Text="NEXA" 
                       VerticalAlignment="Center" 
                       Margin="16,0,0,0" 
                       FontSize="12" 
                       Foreground="#88FFFFFF"/>
        </Grid>

        <controls:NotificationOverlay Canvas.ZIndex="999" />
    </Grid>
</Window>